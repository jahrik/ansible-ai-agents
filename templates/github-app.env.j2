# Managed by the ansible-ai-agents role. Not a secrets file: the private key
# stays in the PEM at GITHUB_APP_PRIVATE_KEY_FILE — only its path is recorded.
GITHUB_APP_ID="{{ ai_agents_mcp_github_app_id }}"
GITHUB_APP_INSTALLATION_ID="{{ ai_agents_mcp_github_app_installation_id }}"
GITHUB_APP_PRIVATE_KEY_FILE="{{ ai_agents_mcp_github_app_private_key_file }}"
